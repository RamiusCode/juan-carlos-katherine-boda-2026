                                    stroke="currentColor"
                                    viewBox="0 0 24 24"
                                    stroke-linecap="round"
                                >
                                    <circle
                                        cx="10.5"
                                        cy="10.5"
                                        r="6.5"
                                        stroke-width="2.5"></circle>
                                    <path
                                        d="M15.5 15.5L21 21"
                                        stroke-width="2.5"></path>
                                    <path
