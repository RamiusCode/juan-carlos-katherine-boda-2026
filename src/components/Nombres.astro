<!-- 🎬 ANIMACIONES CON GSAP                                     -->
<!-- ═══════════════════════════════════════════════════════════ -->
<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  if (typeof window !== "undefined") {
    document.addEventListener("DOMContentLoaded", () => {
      console.log("👨‍👩‍👧‍👦 Iniciando animaciones de padres y padrinos...");

      gsap.set("#texto-bendicion", { opacity: 0, y: 30, scale: 0.95 });
      gsap.set("#seccion-padres-novio", { opacity: 0, y: 30 });
      gsap.set("#seccion-padres-novia", { opacity: 0, y: 30 });
      gsap.set("#seccion-padrinos-anillos", { opacity: 0, y: 30 });
      gsap.set("#seccion-padrinos-civil", { opacity: 0, y: 30 });
      gsap.set("#adorno-izq", { opacity: 0, x: -30 });
      gsap.set("#adorno-der", { opacity: 0, x: 30 });

      ScrollTrigger.create({
        trigger: "#texto-bendicion",
        start: "top 90%",
        end: "top 20%",
        onEnter: () => {
          console.log("✨ Padres y padrinos apareciendo simultáneamente...");
          animarSimultaneo();
        },
        onLeaveBack: () => {
          console.log("👋 Ocultando sección de padres y padrinos...");
          ocultarSimultaneo();
        },
      });

      function animarSimultaneo() {
        gsap.to("#texto-bendicion", {
          opacity: 1,
          y: 0,
          scale: 1,
          duration: 1.2,
          ease: "power3.out",
        });

        const tl = gsap.timeline({ delay: 0.6 });
        tl.to(
          "#adorno-izq, #adorno-der, #seccion-padres-novio, #seccion-padres-novia, #seccion-padrinos-anillos, #seccion-padrinos-civil",
          {
            opacity: 1,
            duration: 1,
            ease: "power2.out",
          },
        )
          .to("#adorno-izq", { x: 0, duration: 1, ease: "power2.out" }, "<")
          .to("#adorno-der", { x: 0, duration: 1, ease: "power2.out" }, "<")
          .to(
            "#seccion-padres-novio, #seccion-padres-novia, #seccion-padrinos-anillos, #seccion-padrinos-civil",
            {
              y: 0,
              duration: 1,
              ease: "power2.out",
            },
            "<",
          );
      }

      function ocultarSimultaneo() {
        const tl = gsap.timeline();
        tl.to(
          "#texto-bendicion, #adorno-izq, #adorno-der, #seccion-padres-novio, #seccion-padres-novia, #seccion-padrinos-anillos, #seccion-padrinos-civil",
          {
            opacity: 0,
            duration: 0.5,
            ease: "power2.in",
          },
        )
          .to("#adorno-izq", { x: -30, duration: 0.5, ease: "power2.in" }, "<")
          .to("#adorno-der", { x: 30, duration: 0.5, ease: "power2.in" }, "<")
          .to(
            "#texto-bendicion, #seccion-padres-novio, #seccion-padres-novia, #seccion-padrinos-anillos, #seccion-padrinos-civil",
            {
              y: 30,
              duration: 0.5,
              ease: "power2.in",
            },
            "<",
          )
          .to(
            "#texto-bendicion",
            { scale: 0.95, duration: 0.5, ease: "power2.in" },
            "<",
          );
      }
    });
  }
</script>

