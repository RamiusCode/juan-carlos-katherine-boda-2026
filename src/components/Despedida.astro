---
// Despedida.astro
---

<section class="py-4 px-4 relative overflow-hidden">
  <div class="max-w-6xl mx-auto relative z-10">
    <div class="max-w-4xl mx-auto text-center">
      <div class="flex justify-center mb-10" id="flores-arriba-despedida">
        <img
          src="/imagenes/Separadores.webp"
          alt="Flores decorativas"
          class="w-40 md:w-48 lg:w-56 h-auto object-contain opacity-90"
        />
      </div>

      <div
        class="relative backdrop-blur-sm bg-white/10 rounded-[2.5rem] border-2 border-[#2E5FA3]/20 p-10 md:p-12 lg:p-16"
        id="card-despedida"
      >
        <div
          class="absolute top-0 left-0 right-0 h-1/2 bg-gradient-to-b from-white/10 to-transparent rounded-t-[2.5rem] pointer-events-none"
        >
        </div>

        <!-- Esquinas decorativas -->
        <div class="absolute top-4 left-4 w-16 h-16">
          <div
            class="absolute top-0 left-0 w-full h-0.5 bg-gradient-to-r from-[#2E5FA3]/40 to-transparent"
          >
          </div>
          <div
            class="absolute top-0 left-0 w-0.5 h-full bg-gradient-to-b from-[#2E5FA3]/40 to-transparent"
          >
          </div>
        </div>
        <div class="absolute top-4 right-4 w-16 h-16">
          <div
            class="absolute top-0 right-0 w-full h-0.5 bg-gradient-to-l from-[#2E5FA3]/40 to-transparent"
          >
          </div>
          <div
            class="absolute top-0 right-0 w-0.5 h-full bg-gradient-to-b from-[#2E5FA3]/40 to-transparent"
          >
          </div>
        </div>
        <div class="absolute bottom-4 left-4 w-16 h-16">
          <div
            class="absolute bottom-0 left-0 w-full h-0.5 bg-gradient-to-r from-[#2E5FA3]/40 to-transparent"
          >
          </div>
          <div
            class="absolute bottom-0 left-0 w-0.5 h-full bg-gradient-to-t from-[#2E5FA3]/40 to-transparent"
          >
          </div>
        </div>
        <div class="absolute bottom-4 right-4 w-16 h-16">
          <div
            class="absolute bottom-0 right-0 w-full h-0.5 bg-gradient-to-l from-[#2E5FA3]/40 to-transparent"
          >
          </div>
          <div
            class="absolute bottom-0 right-0 w-0.5 h-full bg-gradient-to-t from-[#2E5FA3]/40 to-transparent"
          >
          </div>
        </div>

        <div class="relative z-10" id="contenido-completo">
          <!-- Título -->
          <div id="titulo-despedida" class="mb-8">
            <h2 class="font-charm text-3xl text-[#2E5FA3] font-bold mb-4">
              Querida Familia y Amigos
            </h2>
            <div class="flex items-center justify-center gap-3">
              <div
                class="w-16 h-[2px] bg-gradient-to-r from-transparent to-[#2E5FA3]"
              >
              </div>
              <div class="w-2 h-2 rounded-full bg-[#2E5FA3]"></div>
              <div
                class="w-16 h-[2px] bg-gradient-to-l from-transparent to-[#2E5FA3]"
              >
              </div>
            </div>
          </div>

          <!-- Mensaje -->
          <div id="mensaje-despedida" class="space-y-6 mb-10">
            <p
              class="font-charm text-xl md:text-2xl lg:text-3xl text-[#1B3A6B] leading-relaxed"
            >
              Nos llena de felicidad poder compartir con ustedes este momento
              tan único y especial.
            </p>
            <p
              class="font-charm text-xl md:text-2xl lg:text-3xl text-[#1B3A6B] leading-relaxed"
            >
              Con la esperanza de que hagamos de este día un recuerdo
              inolvidable.
            </p>
            <p
              class="font-charm text-xl md:text-2xl lg:text-3xl text-[#1B3A6B] leading-relaxed"
            >
              Los esperamos con los corazones llenos de emoción, listos para
              celebrar el amor y crear memorias que permanezcan siempre en
              nuestros corazones.
            </p>
          </div>

          <!-- Corazón decorativo -->
          <div
            class="flex items-center justify-center gap-4 my-10"
            id="linea-decorativa"
          >
            <div
              class="w-20 h-[1px] bg-gradient-to-r from-transparent via-[#2E5FA3] to-[#2E5FA3]"
            >
            </div>
            <svg
              class="w-8 h-8 text-[#2E5FA3]"
              viewBox="0 0 24 24"
              fill="currentColor"
            >
              <path
                d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"
              ></path>
            </svg>
            <div
              class="w-20 h-[1px] bg-gradient-to-l from-transparent via-[#2E5FA3] to-[#2E5FA3]"
            >
            </div>
          </div>

          <!-- Sección confirmar -->
          <div id="seccion-confirmar" class="mt-10">
            <p
              class="font-charm text-2xl md:text-3xl text-[#2E5FA3] font-bold mb-10"
            >
              Esperamos contar con tu presencia
            </p>

            <!-- Botones -->
            <div
              class="flex flex-col items-center gap-4"
              id="botones-confirmar"
            >
              <a
                href="https://wa.link/dknwma"
                target="_blank"
                rel="noopener noreferrer"
                class="boton-confirmacion"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="20"
                  height="20"
                  fill="currentColor"
                  viewBox="0 0 24 24"
                  style="flex-shrink:0;"
                >
                  <path
                    d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347zM12 0C5.373 0 0 5.373 0 12c0 2.122.553 4.112 1.52 5.84L.057 23.943l6.262-1.643A11.94 11.94 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.792 9.792 0 0 1-5.028-1.382l-.36-.214-3.733.979 1.001-3.64-.236-.375A9.794 9.794 0 0 1 2.182 12C2.182 6.57 6.57 2.182 12 2.182S21.818 6.57 21.818 12 17.43 21.818 12 21.818z"
                  ></path>
                </svg>
                Confirmar con el Novio
              </a>

              <a
                href="https://wa.link/wcghqq"
                target="_blank"
                rel="noopener noreferrer"
                class="boton-confirmacion"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="20"
                  height="20"
                  fill="currentColor"
                  viewBox="0 0 24 24"
                  style="flex-shrink:0;"
                >
                  <path
                    d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347zM12 0C5.373 0 0 5.373 0 12c0 2.122.553 4.112 1.52 5.84L.057 23.943l6.262-1.643A11.94 11.94 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.792 9.792 0 0 1-5.028-1.382l-.36-.214-3.733.979 1.001-3.64-.236-.375A9.794 9.794 0 0 1 2.182 12C2.182 6.57 6.57 2.182 12 2.182S21.818 6.57 21.818 12 17.43 21.818 12 21.818z"
                  ></path>
                </svg>
                Confirmar con la Novia
              </a>
            </div>
          </div>
        </div>
      </div>

      <div class="flex justify-center mt-10" id="flores-abajo-despedida">
        <img
          src="/imagenes/Separadores.webp"
          alt="Flores decorativas"
          class="w-40 md:w-48 lg:w-56 h-auto object-contain opacity-90"
        />
      </div>
    </div>
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  if (typeof window !== "undefined") {
    document.addEventListener("DOMContentLoaded", () => {
      gsap.set("#flores-arriba-despedida", { opacity: 0, y: 20 });
      gsap.set("#card-despedida", { opacity: 0, y: 30 });
      gsap.set("#flores-abajo-despedida", { opacity: 0, y: 20 });

      ScrollTrigger.create({
        trigger: "#flores-arriba-despedida",
        start: "top 85%",
        onEnter: () => {
          const tl = gsap.timeline();
          tl.to(
            "#flores-arriba-despedida",
            { opacity: 1, y: 0, duration: 1, ease: "power2.out" },
            0,
          )
            .to(
              "#card-despedida",
              { opacity: 1, y: 0, duration: 1.2, ease: "power2.out" },
              0.2,
            )
            .to(
              "#flores-abajo-despedida",
              { opacity: 1, y: 0, duration: 1, ease: "power2.out" },
              0.4,
            );

          gsap.to("#linea-decorativa svg", {
            scale: 1.15,
            duration: 2.5,
            ease: "sine.inOut",
            yoyo: true,
            repeat: -1,
            delay: 1.5,
          });

          gsap.to("#botones-confirmar .boton-confirmacion", {
            y: -4,
            duration: 3,
            ease: "sine.inOut",
            yoyo: true,
            repeat: -1,
            delay: 1.5,
            stagger: 0.3,
          });
        },
        onLeaveBack: () => {
          gsap.killTweensOf("#linea-decorativa svg");
          gsap.killTweensOf("#botones-confirmar .boton-confirmacion");
          gsap.set("#flores-arriba-despedida", { opacity: 0, y: 20 });
          gsap.set("#card-despedida", { opacity: 0, y: 30 });
          gsap.set("#flores-abajo-despedida", { opacity: 0, y: 20 });
        },
      });
    });
  }
</script>

<style>
  #card-despedida {
    transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  }
  #card-despedida:hover {
    transform: translateY(-5px);
    box-shadow: 0 20px 40px rgba(46, 95, 163, 0.15);
  }

  /* Botones: azul marino → azul claro en hover */
  .boton-confirmacion {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    padding: 0.75rem 2rem;
    background-color: #1b3a6b;
    color: white;
    border-radius: 9999px;
    font-family: "Charm", cursive;
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-decoration: none;
    white-space: nowrap;
    box-shadow: 0 4px 18px rgba(27, 58, 107, 0.35);
    transition:
      background-color 0.3s ease,
      box-shadow 0.3s ease,
      transform 0.3s ease;
  }
  .boton-confirmacion:hover {
    background-color: #2e5fa3;
    box-shadow: 0 8px 28px rgba(46, 95, 163, 0.45);
    transform: translateY(-3px) scale(1.05);
  }
</style>
