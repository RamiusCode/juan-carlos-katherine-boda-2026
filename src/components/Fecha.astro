<!-- ═══════════════════════════════════════════════════════════ --><!-- 📅 COMPONENTE FECHA - FECHA DEL EVENTO DE BODA             --><!-- ═══════════════════════════════════════════════════════════ -->
<section class="py-2 px-4">
  <div class="max-w-2xl mx-auto text-center relative">
    <!-- 🍃 HOJA IZQUIERDA - PEGADA AL BORDE -->
    <div
      class="absolute left-0 top-1/2 -translate-y-1/3 w-16 pointer-events-none -ml-6 sm:-ml-7 md:-ml-8"
      id="hoja-fecha-izq"
    >
      <img
        src="/imagenes/Hojas.webp"
        alt="Hoja izquierda"
        class="w-full h-auto object-contain transform -scale-x-100"
      />
    </div>

    <!-- 🍃 HOJA DERECHA - PEGADA AL BORDE -->
    <div
      class="absolute right-0 top-1/2 -translate-y-1/3 w-16 pointer-events-none -mr-6 sm:-mr-7 md:-mr-8"
      id="hoja-fecha-der"
    >
      <img
        src="/imagenes/Hojas.webp"
        alt="Hoja derecha"
        class="w-full h-auto object-contain"
      />
    </div>

    <!-- 🌸 Flores centrales arriba -->
    <div class="flex justify-center mb-6" id="flores-fecha">
      <img
        src="/imagenes/Separadores.webp"
        alt="Flores decorativas"
        class="w-40 md:w-48 lg:w-56 h-auto"
      />
    </div>

    <!-- 💍 Texto "Acompáñanos este día tan especial" -->
    <div class="mb-6" id="texto-invitacion-container">
      <div class="flex items-center justify-center px-4">
        <div id="texto-invitacion" class="flex-shrink-0">
          <p
            class="font-great-vibes text-3xl sm:text-3xl md:text-4xl text-[#1B3A6B] leading-relaxed text-center"
          >
            Acompáñanos este día<br />tan especial
          </p>
        </div>
      </div>
    </div>

    <!-- 📅 Fecha con líneas arriba y abajo -->
    <div class="relative max-w-md mx-auto" id="fecha-evento">
      <div class="flex items-center justify-center gap-4 md:gap-6">
        <!-- SÁBADO con líneas arriba y abajo -->
        <div class="flex flex-col items-center w-24 md:w-28">
          <div class="w-full h-px bg-[#2E5FA3] mb-2"></div>
          <span
            class="font-charm text-lg md:text-xl text-[#1B3A6B] uppercase tracking-wider font-bold text-center"
          >
            SÁBADO
          </span>
          <div class="w-full h-px bg-[#2E5FA3] mt-2"></div>
        </div>

        <!-- Número 28 - CENTRADO -->
        <div
          class="flex items-center justify-center min-w-[80px] md:min-w-[100px]"
        >
          <span
            class="font-charm text-7xl md:text-8xl text-[#2E5FA3] font-bold"
          >
            28
          </span>
        </div>

        <!-- MARZO con líneas arriba y abajo -->
        <div class="flex flex-col items-center w-24 md:w-28">
          <div class="w-full h-px bg-[#2E5FA3] mb-2"></div>
          <span
            class="font-charm text-lg md:text-xl text-[#1B3A6B] uppercase tracking-wider font-bold text-center"
          >
            MARZO
          </span>
          <div class="w-full h-px bg-[#2E5FA3] mt-2"></div>
        </div>
      </div>

      <!-- Año 2026 -->
      <div class="mt-4 flex justify-center" id="anio-evento">
        <p class="font-charm text-3xl md:text-4xl text-[#1B3A6B] font-bold">
          2026
        </p>
      </div>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════════════════════ -->
<!-- 🎬 ANIMACIONES CON GSAP                                     -->
<!-- ═══════════════════════════════════════════════════════════ -->
<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  if (typeof window !== "undefined") {
    document.addEventListener("DOMContentLoaded", () => {
      console.log("📅 Iniciando animaciones de fecha...");

      gsap.set("#flores-fecha", { opacity: 0, scale: 0.8 });
      gsap.set("#hoja-fecha-izq", { opacity: 0, x: -30 });
      gsap.set("#hoja-fecha-der", { opacity: 0, x: 30 });
      gsap.set("#texto-invitacion", { opacity: 0, scale: 0.9 });
      gsap.set("#fecha-evento", { opacity: 0, scale: 0.9 });
      gsap.set("#anio-evento", { opacity: 0, scale: 0.9 });

      ScrollTrigger.create({
        trigger: "#flores-fecha",
        start: "top 85%",
        end: "top 20%",

        onEnter: () => {
          const tl = gsap.timeline();
          tl.to(
            "#flores-fecha, #hoja-fecha-izq, #hoja-fecha-der, #texto-invitacion, #fecha-evento, #anio-evento",
            {
              opacity: 1,
              duration: 1,
              ease: "power2.out",
            },
          )
            .to(
              "#flores-fecha",
              { scale: 1, duration: 1, ease: "back.out(1.4)" },
              "<",
            )
            .to(
              "#hoja-fecha-izq",
              { x: 0, duration: 1, ease: "power2.out" },
              "<",
            )
            .to(
              "#hoja-fecha-der",
              { x: 0, duration: 1, ease: "power2.out" },
              "<",
            )
            .to(
              "#texto-invitacion, #fecha-evento, #anio-evento",
              { scale: 1, duration: 1, ease: "back.out(1.2)" },
              "<",
            );
        },

        onLeaveBack: () => {
          const tl = gsap.timeline();
          tl.to(
            "#flores-fecha, #hoja-fecha-izq, #hoja-fecha-der, #texto-invitacion, #fecha-evento, #anio-evento",
            {
              opacity: 0,
              duration: 0.5,
              ease: "power2.in",
            },
          )
            .to(
              "#flores-fecha",
              { scale: 0.8, duration: 0.5, ease: "power2.in" },
              "<",
            )
            .to(
              "#hoja-fecha-izq",
              { x: -30, duration: 0.5, ease: "power2.in" },
              "<",
            )
            .to(
              "#hoja-fecha-der",
              { x: 30, duration: 0.5, ease: "power2.in" },
              "<",
            )
            .to(
              "#texto-invitacion, #fecha-evento, #anio-evento",
              { scale: 0.9, duration: 0.5, ease: "power2.in" },
              "<",
            );
        },
      });

      console.log("✨ Animaciones de fecha listas!");
    });
  }
</script>

